# ---------------------------------------------------------------------------
# Crassus 2.5 -- Environment variables template
# Copy to .env and fill in real values. Never commit real secrets.
# ---------------------------------------------------------------------------

# ===== Required: Alpaca API =====
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ===== Required: Webhook auth (must match X-Webhook-Token header in TradingView) =====
WEBHOOK_AUTH_TOKEN=

# ===== Optional: Dashboard access gate for shared hosting =====
# DASHBOARD_ACCESS_PASSWORD=     # Set this to require a login for the dashboard UI
# DASHBOARD_ACCESS_PASSWORD_HASH=  # Optional Werkzeug hash instead of plaintext password
# DASHBOARD_SESSION_SECRET=      # Recommended for hosted dashboards

# ===== Shared webhook routing =====
# WEBHOOK_FORWARD_TARGET=azure  # azure, local, custom, or none
# WEBHOOK_FORWARD_URL=          # Optional when WEBHOOK_FORWARD_TARGET=custom
# WEBHOOK_ACTIVE_MINUTES=60
# WEBHOOK_MAX_SNAPSHOTS=50

# ===== Azure deployment naming =====
# AZURE_FUNCTION_APP_NAME=crassus-25
# AZURE_FUNCTION_BASE_URL=      # Optional override, e.g. https://your-func.azurewebsites.net
# AZURE_SUBSCRIPTION_ID=        # Required for a hosted dashboard to sync Azure app settings
# AZURE_RESOURCE_GROUP=CRG
# AZURE_LOCATION=eastus
# AZURE_STORAGE_ACCOUNT=crassusstorage25
# AZURE_DASHBOARD_APP_NAME=     # Optional Azure Web App name for a hosted dashboard
# AZURE_DASHBOARD_PLAN_NAME=    # Optional App Service plan name for the hosted dashboard
# AZURE_DASHBOARD_SKU=F1        # App Service SKU for the hosted dashboard (F1=Free, B1=Basic)
# AZURE_USE_KEY_VAULT=true      # Store hosted secrets in Azure Key Vault
# AZURE_KEY_VAULT_NAME=         # Optional override; defaults from the storage account name
# AZURE_KEY_VAULT_SECRET_PREFIX=  # Optional prefix for secret names stored in Key Vault

# ===== Optional: Paper vs live trading (default: true = paper) =====
# ALPACA_PAPER=true
# LIVE_TRADING_CONFIRMED=yes     # Required when ALPACA_PAPER=false

# ===== Optional: Operator safety brakes =====
# TRADING_HALTED=false           # Set true to block all new entries
# TRADING_HALTED_REASON=         # Optional dashboard / log-friendly reason
# MAX_DAILY_LOSS_DOLLARS=        # Block new entries after this daily loss ($)
# MAX_DAILY_LOSS_PCT=            # Block new entries after this daily loss (%)

# ===== Default stock quantity per trade =====
# DEFAULT_STOCK_QTY=1
# MAX_OPEN_POSITIONS=10          # Max concurrent open positions across the account

# ===== Strategy: bollinger_mean_reversion (prefix BMR_) =====
# Stock bracket percentages
# BMR_STOCK_TP_PCT=0.2          # Take-profit 0.2%
# BMR_STOCK_SL_PCT=0.1          # Stop-loss 0.1%
# BMR_STOCK_STOP_LIMIT_PCT=0.15 # Stop-limit 0.15%
# Options bracket percentages (% of premium)
# BMR_OPTIONS_TP_PCT=20.0       # Take-profit 20% of premium
# BMR_OPTIONS_SL_PCT=10.0       # Stop-loss 10% of premium

# ===== Strategy: lorentzian_classification (prefix LC_) =====
# Stock bracket percentages
# LC_STOCK_TP_PCT=1.0            # Take-profit 1.0%
# LC_STOCK_SL_PCT=0.8            # Stop-loss 0.8%
# LC_STOCK_STOP_LIMIT_PCT=0.9    # Stop-limit 0.9%
# Options bracket percentages (% of premium)
# LC_OPTIONS_TP_PCT=50.0         # Take-profit 50% of premium
# LC_OPTIONS_SL_PCT=40.0         # Stop-loss 40% of premium

# ===== Options contract screening defaults =====
# OPTIONS_DTE_MIN=14             # Minimum days to expiration
# OPTIONS_DTE_MAX=45             # Maximum days to expiration
# OPTIONS_DELTA_MIN=0.30         # Min absolute delta (real Greeks via greeks.py)
# OPTIONS_DELTA_MAX=0.70         # Max absolute delta (real Greeks via greeks.py)
# OPTIONS_MIN_OI=100             # Minimum open interest
# OPTIONS_MIN_VOLUME=10          # Minimum daily volume
# OPTIONS_MAX_SPREAD_PCT=5.0     # Max bid-ask spread as % of mid
# OPTIONS_MIN_PRICE=0.50         # Minimum option premium
# OPTIONS_MAX_PRICE=50.0         # Maximum option premium

# ===== Greeks computation =====
# RISK_FREE_RATE=0.05            # Annualized risk-free rate for Black-Scholes (default 5%)

# ===== Yahoo Finance data source =====
# YAHOO_ENABLED=true             # Toggle Yahoo Finance as market data source
# YAHOO_RETRY_COUNT=5            # Max retries for Yahoo API requests
# YAHOO_BACKOFF_BASE=2           # Exponential backoff base (seconds)

# ===== Risk sizing =====
# MAX_DOLLAR_RISK=50.0           # Max $ risk per options trade
# RISK_PCT_OF_EQUITY=            # Future: % of account equity (not yet used)

# ===== Idempotency / monitoring =====
# DEDUP_TTL_SECONDS=60           # How long to reject duplicate webhook fingerprints
# SIGNAL_DEDUP_CONTAINER=signal-dedup  # Azure Blob container for shared dedup keys
# OPTIONS_TARGETS_CONTAINER=options-exit-targets  # Azure Blob container for tracked options exits
# STALE_ORDER_MINUTES=120        # Cancel lingering stock entry orders after this many minutes
